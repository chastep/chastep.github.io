---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getPublishedPosts, getAllCategories, groupByCategory } from '@/utils/helpers';

const posts = await getCollection('posts');
const publishedPosts = getPublishedPosts(posts);
const categories = getAllCategories(publishedPosts);
const byCategory = groupByCategory(publishedPosts);
---

<BaseLayout title="Categories">
  <div class="archive">
    <h1>Categories</h1>
    <ul class="archive__list">
      {categories.map((cat) => (
        <li>
          <a href={`/categories/${cat.toLowerCase().replace(/\s+/g, '-')}`}>
            {cat} <span class="archive__count">({byCategory[cat].length})</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .archive__list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .archive__list li {
    padding: 12px 0;
    border-bottom: 1px solid var(--color-background);
  }

  .archive__list a {
    color: inherit;
    text-decoration: none;
  }

  .archive__list a:hover {
    text-decoration: underline;
  }

  .archive__count {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }
</style>
